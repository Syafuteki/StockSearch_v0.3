POSTGRES_USER=jpswing
POSTGRES_PASSWORD=CHANGE_TO_LONG_RANDOM_PASSWORD
POSTGRES_DB=jpswing
JQUANTS_API_KEY=
EDINET_API_KEY=
EDINET_BASE_URL=https://api.edinet-fsa.go.jp
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_TECH=
DISCORD_WEBHOOK_THEME=
DISCORD_WEBHOOK_FUND_INTEL=
DISCORD_WEBHOOK_FUND_INTEL_FLASH=
DISCORD_WEBHOOK_FUND_INTEL_DETAIL=
DISCORD_WEBHOOK_PROPOSALS=
DATABASE_URL=postgresql+psycopg://jpswing:CHANGE_TO_LONG_RANDOM_PASSWORD@postgres:5432/jpswing
# Common LM Studio / OpenAI-compatible settings
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_API_KEY=
LLM_MODEL_NAME=gpt-oss-20b
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SEC=120
# Optional Intel-specific overrides. Leave blank to inherit the common settings.
INTEL_LLM_MODEL_NAME=
INTEL_LLM_TEMPERATURE=0.0
INTEL_LLM_TIMEOUT_SEC=
INTEL_LLM_RETRIES=2
EMBEDDING_BASE_URL=http://host.docker.internal:1234/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=text-embedding-nomic-embed-text-v1.5
# Optional Intel MCP settings. INTEL_USE_MCP=true alone is not enough;
# also set INTEL_MCP_PLUGIN_IDS, INTEL_MCP_SERVER, or search.mcp_integrations.
# INTEL_MCP_ENDPOINT is an optional source-search backend endpoint.
# INTEL_LMSTUDIO_CHAT_ENDPOINT overrides the LM Studio /api/v1/chat endpoint for Intel LLM MCP.
INTEL_MCP_ENDPOINT=
INTEL_USE_MCP=true
INTEL_MCP_SERVER=
INTEL_MCP_PLUGIN_IDS=
INTEL_MCP_CONTEXT_LENGTH=64000
INTEL_LMSTUDIO_CHAT_ENDPOINT=
ALPHAVANTAGE_API_KEY=

